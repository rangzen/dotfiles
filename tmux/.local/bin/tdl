#!/usr/bin/env bash
# Usage: tdl <ai> [<second_ai>]
# Create dev layout: editor (nvim) + AI pane(s) + terminal strip
[[ -z $1 ]] && { echo "Usage: tdl <ai> [<ai2>]"; echo "  <ai>, <ai2>  CLI command to launch in the AI pane(s), e.g. claude, opencode, gemini, mods"; exit 1; }
[[ -z $TMUX ]] && { echo "You must start tmux to use tdl."; exit 1; }

current_dir="${PWD}"
ai="$1"
ai2="$2"

editor_pane="$TMUX_PANE"

tmux rename-window -t "$editor_pane" "$(basename "$current_dir")"

# Bottom strip 15%
tmux split-window -v -l 15% -t "$editor_pane" -c "$current_dir"

# AI pane on right 30%
ai_pane=$(tmux split-window -h -l 30% -t "$editor_pane" -c "$current_dir" -P -F '#{pane_id}')

if [[ -n $ai2 ]]; then
  ai2_pane=$(tmux split-window -v -t "$ai_pane" -c "$current_dir" -P -F '#{pane_id}')
  tmux send-keys -t "$ai2_pane" "$ai2" C-m
fi

tmux send-keys -t "$ai_pane" "$ai" C-m
tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
tmux select-pane -t "$editor_pane"
